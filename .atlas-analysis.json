  "keyFeatures": [
    "Multiple Bible translations via API.Bible integration",
    "Advanced scripture search with highlighted results",
    "Personal verse collections for organizing favorite passages",
    "Rich text notes with Plate.js editor for Bible chapters",
    "AI-powered story generation using Google Gemini",
    "Secure authentication with Better Auth",
    "Real-time data sync with Convex backend",
    "Responsive design for desktop and mobile"
  ],
  "publicApiSurface": [
    "getBibles() - Fetch available Bible translations",
    "getBooks(bibleId) - Get books for a Bible translation",
    "getChapter(bibleId, chapterId) - Retrieve chapter content",
    "searchVerse(bibleId, query, offset) - Search Bible verses",
    "createCollection(name, userId) - Create verse collection",
    "getCollection(id, userId) - Get collection with verses",
    "updateCollection(id, name, userId) - Update collection name",
    "deleteCollection(id, userId) - Delete collection",
    "addVerseToCollection(collectionId, verse) - Add verse to collection",
    "removeVerseFromCollection(verseId, userId) - Remove verse from collection",
    "createNote(chapterId, content, userId) - Create chapter note",
    "getNote(chapterId, userId) - Get note for chapter",
    "updateNote(chapterId, content, userId) - Update chapter note",
    "createStory(params) - Generate AI-powered story",
    "getStories(userId) - List user's stories",
    "getStory(id, userId) - Get single story",
    "deleteStory(id, userId) - Delete story"
  ]
}
